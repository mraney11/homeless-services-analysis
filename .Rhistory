dir.create(file.path(project_dir, "report"), showWarnings = FALSE)
dir.create(file.path(project_dir, "outputs"), showWarnings = FALSE)
set.seed(42)
# 2. CREATE SYNTHETIC NONPROFIT HOUSING DATA ----
n <- 200
housing <- tibble(
client_id = paste0("C", 1001:(1000 + n)),
age = round(pmin(pmax(rnorm(n, 41, 13), 18), 78)),
gender = sample(c("Female", "Male", "Nonbinary", "Unknown"), n, replace = TRUE,
prob = c(.46, .45, .04, .05)),
race_ethnicity = sample(
c("Black", "White", "Hispanic/Latino", "Multiracial", "Asian", "Native American", "Unknown"),
n, replace = TRUE,
prob = c(.38, .28, .18, .07, .03, .03, .03)
),
veteran_status = sample(c("Yes", "No"), n, replace = TRUE, prob = c(.12, .88)),
household_size = sample(1:6, n, replace = TRUE, prob = c(.52, .22, .13, .07, .04, .02)),
prior_homeless_episodes = sample(0:5, n, replace = TRUE,
prob = c(.22, .28, .22, .15, .08, .05)),
monthly_income = round(pmax(rnorm(n, 840, 520), 0)),
employment_status = sample(
c("Employed", "Unemployed", "Disabled", "Retired", "Student"),
n, replace = TRUE,
prob = c(.31, .42, .18, .06, .03)
),
mental_health_flag = sample(c("Yes", "No"), n, replace = TRUE, prob = c(.36, .64)),
substance_use_flag = sample(c("Yes", "No"), n, replace = TRUE, prob = c(.24, .76)),
program_type = sample(
c("Rapid Re-Housing", "Emergency Shelter", "Transitional Housing", "Permanent Supportive Housing"),
n, replace = TRUE,
prob = c(.34, .32, .20, .14)
),
services_received_count = pmin(rpois(n, 4) + 1, 12),
length_of_stay_days = round(pmax(rnorm(n, 95, 55), 3)),
rental_assistance_amount = round(pmax(rnorm(n, 850, 520), 0)),
case_manager_assigned = sample(c("Yes", "No"), n, replace = TRUE, prob = c(.78, .22))
)
housing <- housing %>%
mutate(
success_score =
-0.25 +
0.55 * (case_manager_assigned == "Yes") +
0.12 * services_received_count +
0.0004 * rental_assistance_amount +
0.0003 * monthly_income -
0.25 * prior_homeless_episodes -
0.30 * (mental_health_flag == "Yes") -
0.25 * (substance_use_flag == "Yes") +
0.50 * (program_type == "Rapid Re-Housing") -
0.35 * (program_type == "Emergency Shelter"),
probability_success = 1 / (1 + exp(-success_score)),
outcome_success = if_else(runif(n) < probability_success, "Yes", "No"),
exit_destination = if_else(
outcome_success == "Yes",
"Permanent Housing",
sample(c("Temporary Housing", "Returned to Homelessness", "Unknown"),
n, replace = TRUE, prob = c(.48, .39, .13))
)
) %>%
select(-success_score, -probability_success)
# Add realistic messiness
housing_raw <- housing
housing_raw$monthly_income[sample(1:n, 12)] <- NA
housing_raw$employment_status[sample(1:n, 8)] <- NA
housing_raw$mental_health_flag[sample(1:n, 8)] <- NA
housing_raw$substance_use_flag[sample(1:n, 6)] <- NA
housing_raw$exit_destination[sample(1:n, 6)] <- NA
housing_raw$age[sample(1:n, 1)] <- 104
housing_raw$monthly_income[sample(1:n, 1)] <- -50
housing_raw$monthly_income[sample(1:n, 1)] <- 9999
housing_raw$length_of_stay_days[sample(1:n, 2)] <- c(999, 1200)
housing_raw$case_manager_assigned[sample(1:n, 5)] <- "Y"
housing_raw$mental_health_flag[sample(1:n, 4)] <- "yes"
housing_raw$substance_use_flag[sample(1:n, 4)] <- "NO"
write_csv(housing_raw, file.path(project_dir, "data", "nonprofit_housing_raw.csv"))
write_csv(housing, file.path(project_dir, "data", "nonprofit_housing_clean_reference.csv"))
# 3. DATA DICTIONARY ----
data_dictionary <- tibble(
variable = names(housing_raw),
description = c(
"Unique synthetic client identifier",
"Client age in years",
"Self-reported gender",
"Self-reported race/ethnicity",
"Veteran status",
"Number of people in household",
"Prior homelessness episodes",
"Monthly income at intake",
"Employment status at intake",
"Mental health need flag",
"Substance use need flag",
"Housing program type",
"Number of supportive services received",
"Days enrolled in program",
"Rental assistance amount",
"Case manager assignment",
"Housing destination at program exit",
"Target variable: Yes if permanent housing exit"
)
)
write_csv(data_dictionary, file.path(project_dir, "data", "data_dictionary.csv"))
# 4. R SCRIPTS ----
writeLines('
library(tidyverse)
library(here)
library(skimr)
library(janitor)
housing_raw <- read_csv(here("data", "nonprofit_housing_raw.csv"), show_col_types = FALSE)
glimpse(housing_raw)
skim(housing_raw)
missing_summary <- housing_raw %>%
summarise(across(everything(), ~sum(is.na(.)))) %>%
pivot_longer(everything(), names_to = "variable", values_to = "missing_count") %>%
mutate(missing_percent = round(missing_count / nrow(housing_raw), 3)) %>%
arrange(desc(missing_count))
print(missing_summary)
write_csv(missing_summary, here("outputs", "missing_summary.csv"))
', file.path(project_dir, "scripts", "01_data_inspection.R"))
writeLines('
library(tidyverse)
library(here)
library(janitor)
housing_raw <- read_csv(here("data", "nonprofit_housing_raw.csv"), show_col_types = FALSE)
housing_clean <- housing_raw %>%
clean_names() %>%
mutate(
case_manager_assigned = case_when(
case_manager_assigned %in% c("Y", "Yes", "yes") ~ "Yes",
case_manager_assigned %in% c("N", "No", "no") ~ "No",
TRUE ~ case_manager_assigned
),
mental_health_flag = case_when(
mental_health_flag %in% c("yes", "Yes", "Y") ~ "Yes",
mental_health_flag %in% c("no", "No", "NO", "N") ~ "No",
TRUE ~ mental_health_flag
),
substance_use_flag = case_when(
substance_use_flag %in% c("yes", "Yes", "Y") ~ "Yes",
substance_use_flag %in% c("no", "No", "NO", "N") ~ "No",
TRUE ~ substance_use_flag
),
age = if_else(age < 18 | age > 90, NA_real_, as.numeric(age)),
monthly_income = if_else(monthly_income < 0 | monthly_income > 6000, NA_real_, as.numeric(monthly_income)),
length_of_stay_days = if_else(length_of_stay_days > 730, NA_real_, as.numeric(length_of_stay_days)),
successful_exit = if_else(outcome_success == "Yes", 1, 0)
)
write_csv(housing_clean, here("outputs", "housing_clean.csv"))
', file.path(project_dir, "scripts", "02_data_cleaning.R"))
writeLines('
library(tidyverse)
library(here)
library(scales)
housing_clean <- read_csv(here("outputs", "housing_clean.csv"), show_col_types = FALSE)
program_outcomes <- housing_clean %>%
group_by(program_type) %>%
summarise(
clients = n(),
success_rate = mean(successful_exit, na.rm = TRUE),
avg_services = mean(services_received_count, na.rm = TRUE),
avg_length_of_stay = mean(length_of_stay_days, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(success_rate))
print(program_outcomes)
write_csv(program_outcomes, here("outputs", "program_outcomes.csv"))
ggplot(program_outcomes, aes(reorder(program_type, success_rate), success_rate)) +
geom_col() +
coord_flip() +
scale_y_continuous(labels = percent) +
labs(
title = "Permanent Housing Exit Rate by Program Type",
x = NULL,
y = "Permanent Housing Exit Rate"
) +
theme_minimal()
', file.path(project_dir, "scripts", "03_eda.R"))
writeLines('
library(tidyverse)
library(here)
library(broom)
housing_clean <- read_csv(here("outputs", "housing_clean.csv"), show_col_types = FALSE)
model_data <- housing_clean %>%
mutate(outcome_success = factor(outcome_success, levels = c("No", "Yes"))) %>%
drop_na(
outcome_success,
monthly_income,
prior_homeless_episodes,
services_received_count,
rental_assistance_amount,
case_manager_assigned,
mental_health_flag,
substance_use_flag,
program_type
)
housing_model <- glm(
outcome_success ~ services_received_count +
prior_homeless_episodes +
monthly_income +
rental_assistance_amount +
case_manager_assigned +
mental_health_flag +
substance_use_flag +
program_type,
data = model_data,
family = binomial
)
model_results <- tidy(housing_model, exponentiate = TRUE, conf.int = TRUE)
print(model_results)
write_csv(model_results, here("outputs", "logistic_model_results.csv"))
', file.path(project_dir, "scripts", "04_modeling.R"))
