# ============================================================
# PROMPT 5 — MASTER MODELING SYSTEM
# File Name: 05_modeling.R
# Purpose: Build, evaluate, and interpret statistical models
# ============================================================
library(tidyverse)
library(broom)
project_dir <- "/Users/michaelraney/Antigravity/homeless_services_project"
data_path <- file.path(project_dir, "data", "homeless_services_clean.csv")
outputs_dir <- file.path(project_dir, "outputs")
figures_dir <- file.path(project_dir, "figures")
dir.create(outputs_dir, showWarnings = FALSE, recursive = TRUE)
dir.create(figures_dir, showWarnings = FALSE, recursive = TRUE)
if (!file.exists(data_path)) {
stop("ERROR: Clean dataset not found at: ", data_path)
}
# ============================================================
# PROMPT 5 — MASTER MODELING SYSTEM
# File Name: 05_modeling.R
# Purpose: Build, evaluate, and interpret statistical models
# ============================================================
library(tidyverse)
library(broom)
project_dir <- "/Users/michaelraney/Antigravity/homeless_services_project:"
data_path <- file.path(project_dir, "data", "homeless_services_clean.csv")
outputs_dir <- file.path(project_dir, "outputs")
figures_dir <- file.path(project_dir, "figures")
dir.create(outputs_dir, showWarnings = FALSE, recursive = TRUE)
dir.create(figures_dir, showWarnings = FALSE, recursive = TRUE)
if (!file.exists(data_path)) {
stop("ERROR: Clean dataset not found at: ", data_path)
}
df_clean <- readr::read_csv(data_path, show_col_types = FALSE)
income_col <- if ("monthly_income_at_entry" %in% names(df_clean)) {
"monthly_income_at_entry"
} else {
"monthly_income_at_exit"
}
model_df <- df_clean %>%
select(
exit_status,
age,
length_of_stay,
program_type,
all_of(income_col)
) %>%
rename(monthly_income_at_entry = all_of(income_col)) %>%
mutate(
permanent_exit = exit_status == "Permanent"
) %>%
drop_na()
cat("\nRows available for modeling:", nrow(model_df), "\n")
model_logit <- glm(
permanent_exit ~ age + length_of_stay + program_type + monthly_income_at_entry,
data = model_df,
family = binomial()
)
cat("\n--- Logistic Regression Summary ---\n")
print(summary(model_logit))
logit_results <- broom::tidy(model_logit, conf.int = TRUE)
write_csv(
logit_results,
file.path(outputs_dir, "logit_results.csv")
)
model_linear <- lm(
length_of_stay ~ age + program_type + monthly_income_at_entry,
data = model_df
)
cat("\n--- Linear Regression Summary ---\n")
print(summary(model_linear))
linear_results <- broom::tidy(model_linear, conf.int = TRUE)
write_csv(
linear_results,
file.path(outputs_dir, "linear_results.csv")
)
png(file.path(figures_dir, "model_linear_diagnostics.png"), width = 800, height = 600)
par(mfrow = c(2, 2))
plot(model_linear)
dev.off()
cat("\nModel diagnostics saved to figures/\n")
model_df$pred_prob <- predict(model_logit, type = "response")
model_df$pred_class <- ifelse(model_df$pred_prob > 0.5, "Permanent", "Other")
perf_table <- table(
Predicted = model_df$pred_class,
Actual = model_df$exit_status
)
cat("\n--- Model Performance ---\n")
print(perf_table)
write_csv(
as.data.frame(perf_table),
file.path(outputs_dir, "model_performance_table.csv")
)
cat("\nOutputs saved to:\n")
cat(outputs_dir, "\n")
cat(figures_dir, "\n")
